// ============================================================================
// secrets.h.example — per-deployment credentials for the WiFi+MQTT node
// ----------------------------------------------------------------------------
// COPY this file to  include/secrets.h  and fill in your values.
//   cp include/secrets.h.example include/secrets.h     (Linux/macOS)
//   copy include\secrets.h.example include\secrets.h   (Windows cmd)
//
// include/secrets.h is GITIGNORED (see firmware/.gitignore) — never commit real
// WiFi passwords / broker creds. config.h includes secrets.h automatically (via
// __has_include) and these #defines override the demo defaults in config.h
// because every default there is wrapped in #ifndef.
//
// The LoRa-only node does NOT need this file; if include/secrets.h is absent the
// LoRa build still compiles using the config.h defaults.
// ============================================================================

#ifndef ANGAWATCH_SECRETS_H
#define ANGAWATCH_SECRETS_H

// ---- WiFi ------------------------------------------------------------------
#define WIFI_SSID       "your-wifi-ssid"
#define WIFI_PASSWORD   "your-wifi-password"

// ---- MQTT broker (the SAME broker the backend + dashboard use) -------------
// Point this at the host running the broker (scripts/dev_broker.py for local dev,
// or your production broker). Use 8883 + a WiFiClientSecure for TLS.
#define MQTT_HOST       "192.168.1.10"   // broker IP / hostname
#define MQTT_PORT       1883
#define MQTT_USER       ""               // "" -> connect without authentication
#define MQTT_PASS       ""

// ---- Node identity (MUST match the seeded backend records) -----------------
// IMPORTANT: ORG_ID for the WiFi node is the Organization's UUID, NOT the
// "demo-coop" slug — the backend consumer parses {org_id} from the topic as a
// UUID (app/ingestion/consumer.py). Get the UUID from the seeded org (e.g. the
// dashboard URL, the API, or `select id from organizations where slug='demo-coop'`).
#define ORG_ID            "00000000-0000-0000-0000-000000000000"  // <-- org UUID
#define DEVICE_UID        "GH1-NODE-01"   // == Device.device_uid (relay-bearing node)
#define VENT_ACTUATOR_UID "GH1-VENT-01"   // == the vent ActuatorDevice.name

// ---- Vent relay GPIO -------------------------------------------------------
// HIGH = vent open, LOW = vent closed. Defaults to GPIO 12 in config.h; override
// here if your board wires the vent relay elsewhere. Keep it distinct from
// PIN_ALERT_RELAY (the local buzzer) so both can be driven independently.
#define PIN_VENT_RELAY    12

// ---- Optional tuning -------------------------------------------------------
// Telemetry publish cadence in seconds (always-on node; not a sleep interval).
// #define TELEMETRY_INTERVAL_S  10UL

// Set to 1 to enable ArduinoOTA on this WiFi node (it is already on the network).
// #define OTA_ENABLED  1

#endif  // ANGAWATCH_SECRETS_H
