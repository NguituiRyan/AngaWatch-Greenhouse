# ============================================================================
# AngaWatch Greenhouse — environment configuration (12-factor)
# Copy to `.env` and fill in real values. NEVER commit `.env`.
# ============================================================================

# ---- Compose ----
COMPOSE_PROJECT_NAME=angawatch
ENVIRONMENT=local                      # local | staging | production
LOG_LEVEL=INFO
TZ=Africa/Nairobi

# ---- Postgres + TimescaleDB ----
POSTGRES_USER=angawatch
POSTGRES_PASSWORD=angawatch
POSTGRES_DB=angawatch
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# SQLAlchemy async URL (used by backend). Host machine: postgres -> localhost
DATABASE_URL=postgresql+asyncpg://angawatch:angawatch@postgres:5432/angawatch
# Sync URL (used by Alembic + Celery sync paths)
DATABASE_URL_SYNC=postgresql+psycopg://angawatch:angawatch@postgres:5432/angawatch

# ---- Redis (Celery broker + result backend + cache) ----
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ---- MQTT broker (Mosquitto) ----
MQTT_HOST=mosquitto
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TELEMETRY_TOPIC=farm/+/+/telemetry
MQTT_CLIENT_ID=angawatch-ingestion

# ---- Auth / security ----
JWT_SECRET=change-me-in-production-please-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=14

# ---- API ----
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:5173,http://localhost:3000
SECRET_KEY=change-me-too

# ---- Risk engine scheduling ----
RISK_EVAL_INTERVAL_MINUTES=10
WEATHER_POLL_INTERVAL_MINUTES=30

# ---- Alerting: Africa's Talking (SMS / USSD) ----
ALERTING_DEFAULT_CHANNEL=console        # console | sms | whatsapp
AT_USERNAME=sandbox
AT_API_KEY=
AT_SENDER_ID=ANGAWATCH
AT_USE_SANDBOX=true

# ---- Alerting: WhatsApp Cloud API (Meta) ----
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_API_VERSION=v21.0
WHATSAPP_VERIFY_TOKEN=angawatch-verify

# ---- Payments: M-Pesa Daraja (sandbox) ----
MPESA_ENVIRONMENT=sandbox               # sandbox | production
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=174379
MPESA_PASSKEY=bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919
MPESA_CALLBACK_BASE_URL=https://example.ngrok.io
MPESA_TRANSACTION_TYPE=CustomerPayBillOnline

# ---- Weather provider ----
WEATHER_PROVIDER=mock                   # mock | openweather | tomorrowio
OPENWEATHER_API_KEY=
TOMORROWIO_API_KEY=

# ---- Simulator ----
SIM_ORG_ID=
SIM_NODE_COUNT=3
SIM_SCENARIO=normal                     # normal | blight_dusk | heat_stress | pest_surge | nutrient_depletion | leak | offline
SIM_INTERVAL_SECONDS=5
SIM_TIME_ACCEL=1.0                      # >1 speeds up simulated clock for demos
